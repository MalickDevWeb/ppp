{
  "name": "mon-ecole",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "kill-ports": "lsof -ti tcp:3001,5173 | xargs kill -9 2>/dev/null; true",
    "dev:api": ". $HOME/.nvm/nvm.sh && nvm use 20 --silent && NODE_ENV=development npx tsx server-api.ts",
    "dev:frontend": ". $HOME/.nvm/nvm.sh && nvm use 20 --silent && npx vite",
    "dev": "npm run kill-ports && . $HOME/.nvm/nvm.sh && nvm use 20 --silent && npx concurrently -k -p '[{name}]' -n 'API,VITE' -c 'bgRed.bold,bgBlue.bold' 'npx tsx server-api.ts' 'npx vite'",
    "build": ". $HOME/.nvm/nvm.sh && nvm use 20 --silent && npx vite build",
    "start": "npm run kill-ports && . $HOME/.nvm/nvm.sh && nvm use 20 --silent && NODE_ENV=production node dist/server.cjs",
    "lint": "eslint .",
    "preview": "npm run build && npx vite preview"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/cors": "^2.8.19",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/babel__core": "^7.20.5",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "json-server": "^0.17.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.21"
  }
}
